{
  "id": "misskey",
  "name": "Misskey Channel",
  "description": "Misskey Streaming API channel for OpenClaw, using misskey-llm-cli (what) binary",
  "version": "0.1.0",
  "channels": ["misskey"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "cliBinary": {
        "type": "string",
        "description": "Path to the 'what' CLI binary. If omitted, searches PATH."
      },
      "mentionOnly": {
        "type": "boolean",
        "description": "If true, only process messages that mention the bot user."
      },
      "adminUsers": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of usernames with admin privileges (e.g. can use admin-only commands)."
      },
      "autonomousPost": {
        "type": "object",
        "description": "Periodic autonomous posting configuration. The bot will use its LLM to generate and post notes at a regular interval.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable periodic autonomous posting."
          },
          "intervalMinutes": {
            "type": "number",
            "description": "Interval between posts in minutes (default: 60)."
          },
          "visibility": {
            "type": "string",
            "enum": ["public", "home", "followers"],
            "description": "Visibility for autonomous posts (default: public)."
          },
          "prompt": {
            "type": "string",
            "description": "System prompt for generating autonomous posts. If omitted, a default prompt is used."
          }
        }
      }
    }
  },
  "uiHints": {
    "cliBinary": {
      "label": "CLI Binary Path",
      "placeholder": "/usr/local/bin/what"
    },
    "mentionOnly": {
      "label": "Mention-only mode"
    },
    "adminUsers": {
      "label": "Admin Users",
      "placeholder": "[\"c30\"]"
    },
    "autonomousPost": {
      "label": "Autonomous Posting",
      "placeholder": "{\"enabled\": true, \"intervalMinutes\": 60, \"visibility\": \"public\"}"
    }
  }
}
